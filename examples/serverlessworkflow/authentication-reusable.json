{
  "key": "bearer-auth",
  "id": "examples.bearer-auth",
  "version": "0.1.0",
  "profile": "https://serverlessworkflow.io/specification/1.0.3",
  "queryLanguage": "jq",
  "initial": "getPet",
  "states": {
    "getPet": {
      "invoke": [
        {
          "src": "serverlessworkflow.call",
          "input": {
            "call": "http",
            "with": {
              "method": "get",
              "endpoint": {
                "uri": "https://petstore.swagger.io/v2/pet/{petId}",
                "authentication": {
                  "use": "petStoreAuth"
                }
              }
            }
          },
          "onDone": {
            "target": "done"
          }
        }
      ]
    },
    "done": {
      "type": "final"
    }
  },
  "meta": {
    "serverlessworkflow": {
      "source": "authentication-reusable.yaml",
      "document": {
        "dsl": "1.0.3",
        "namespace": "examples",
        "name": "bearer-auth",
        "version": "0.1.0"
      },
      "use": {
        "authentications": {
          "petStoreAuth": {
            "bearer": {
              "token": "{{ .token }}"
            }
          }
        }
      }
    }
  }
}
