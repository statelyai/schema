{
  "key": "set",
  "id": "test.set",
  "version": "0.1.0",
  "profile": "https://serverlessworkflow.io/specification/1.0.3",
  "queryLanguage": "jq",
  "initial": "schedule",
  "states": {
    "schedule": {
      "invoke": [
        {
          "src": "serverlessworkflow.schedule",
          "input": {
            "on": {
              "one": {
                "with": {
                  "type": "io.serverlessworkflow.samples.events.trigger.v1"
                }
              }
            }
          },
          "onDone": {
            "target": "initialize"
          }
        }
      ]
    },
    "initialize": {
      "entry": [
        {
          "type": "serverlessworkflow.set",
          "params": "{{ $workflow.input[0] }}"
        }
      ],
      "always": {
        "target": "done"
      }
    },
    "done": {
      "type": "final"
    }
  },
  "meta": {
    "serverlessworkflow": {
      "source": "set-expression.yaml",
      "document": {
        "dsl": "1.0.3",
        "namespace": "test",
        "name": "set",
        "version": "0.1.0"
      }
    }
  }
}
