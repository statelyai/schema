{
  "key": "emit",
  "id": "test.emit",
  "version": "0.1.0",
  "profile": "https://serverlessworkflow.io/specification/1.0.3",
  "queryLanguage": "jq",
  "initial": "emitEvent",
  "states": {
    "emitEvent": {
      "entry": [
        {
          "type": "serverlessworkflow.emit",
          "params": {
            "event": {
              "with": {
                "source": "https://petstore.com",
                "type": "com.petstore.order.placed.v1",
                "data": {
                  "client": {
                    "firstName": "Cruella",
                    "lastName": "de Vil"
                  },
                  "items": [
                    {
                      "breed": "dalmatian",
                      "quantity": 101
                    }
                  ]
                }
              }
            }
          }
        }
      ],
      "always": {
        "target": "done"
      }
    },
    "done": {
      "type": "final"
    }
  },
  "meta": {
    "serverlessworkflow": {
      "source": "emit.yaml",
      "document": {
        "dsl": "1.0.3",
        "namespace": "test",
        "name": "emit",
        "version": "0.1.0"
      }
    }
  }
}
