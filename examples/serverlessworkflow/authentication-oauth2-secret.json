{
  "key": "oauth2-authentication",
  "id": "examples.oauth2-authentication",
  "version": "1.0.0",
  "profile": "https://serverlessworkflow.io/specification/1.0.3",
  "queryLanguage": "jq",
  "initial": "getPet",
  "states": {
    "getPet": {
      "invoke": [
        {
          "src": "serverlessworkflow.call",
          "input": {
            "call": "http",
            "with": {
              "method": "get",
              "endpoint": {
                "uri": "https://petstore.swagger.io/v2/pet/{petId}",
                "authentication": {
                  "oauth2": {
                    "use": "mySecret"
                  }
                }
              }
            }
          },
          "onDone": {
            "target": "done"
          }
        }
      ]
    },
    "done": {
      "type": "final"
    }
  },
  "meta": {
    "serverlessworkflow": {
      "source": "authentication-oauth2-secret.yaml",
      "document": {
        "dsl": "1.0.3",
        "namespace": "examples",
        "name": "oauth2-authentication",
        "version": "1.0.0"
      },
      "use": {
        "secrets": [
          "mySecret"
        ]
      }
    }
  }
}
