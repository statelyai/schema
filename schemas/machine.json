{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "description": "The state node ID",
      "type": "string"
    },
    "description": {
      "description": "The text description of this state node",
      "type": "string"
    },
    "type": {
      "description": "The state type, if not a normal (atomic or compound) state node",
      "anyOf": [
        {
          "type": "string",
          "const": "parallel"
        },
        {
          "type": "string",
          "const": "history"
        },
        {
          "type": "string",
          "const": "final"
        }
      ]
    },
    "target": {
      "description": "The target state for history states",
      "type": "string"
    },
    "history": {
      "description": "The history type for history states",
      "type": "string",
      "enum": [
        "shallow",
        "deep"
      ]
    },
    "entry": {
      "description": "The entry actions",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Action"
      }
    },
    "exit": {
      "description": "The exit actions",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Action"
      }
    },
    "initial": {
      "description": "The initial child state",
      "type": "string"
    },
    "on": {
      "description": "The transitions",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "array",
            "items": {
              "$ref": "#/$defs/Transition"
            }
          },
          {
            "$ref": "#/$defs/Transition"
          }
        ]
      }
    },
    "after": {
      "description": "Delayed transitions. Keys can be milliseconds (number as string) or ISO 8601 durations (e.g. PT30S, PT1M).",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "array",
            "items": {
              "$ref": "#/$defs/Transition"
            }
          },
          {
            "$ref": "#/$defs/Transition"
          }
        ]
      }
    },
    "always": {
      "description": "Eventless transitions that trigger immediately when their guard is true",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Transition"
          }
        },
        {
          "$ref": "#/$defs/Transition"
        }
      ]
    },
    "onDone": {
      "description": "Transitions triggered when this state reaches done status",
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Transition"
          }
        },
        {
          "$ref": "#/$defs/Transition"
        }
      ]
    },
    "invoke": {
      "description": "Invoked actors spawned when the state is entered",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Invoke"
      }
    },
    "tags": {
      "description": "Tags for categorizing this state",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output": {
      "description": "Output data for final states",
      "anyOf": [
        {
          "description": "An expression string delimited by {{ }}",
          "type": "string",
          "pattern": "^\\{\\{[\\s\\S]*\\}\\}$"
        },
        {
          "$ref": "#/$defs/__schema0"
        }
      ]
    },
    "meta": {
      "description": "The metadata for this state node",
      "$ref": "#/$defs/Meta"
    },
    "states": {
      "description": "The child states",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/State"
      }
    },
    "key": {
      "description": "The root machine key used as the canonical path root",
      "type": "string",
      "minLength": 1
    },
    "version": {
      "description": "The machine version",
      "type": "string"
    },
    "profile": {
      "description": "Execution profile short name or URI",
      "type": "string"
    },
    "queryLanguage": {
      "description": "The expression language used for evaluating expressions in the machine",
      "type": "string"
    },
    "context": {
      "description": "Initial context values",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      }
    },
    "schemas": {
      "type": "object",
      "properties": {
        "input": {
          "description": "JSON Schema for machine input",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        },
        "context": {
          "description": "JSON Schema definitions for each context property",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "description": "A JSON Schema property definition",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "events": {
          "description": "JSON Schema definitions for each event payload by event type",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "description": "A JSON Schema property definition",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "output": {
          "description": "JSON Schema for machine output",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "key"
  ],
  "additionalProperties": false,
  "$defs": {
    "Action": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "core.assign"
            },
            "assignments": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "anyOf": [
                  {
                    "description": "An expression string delimited by {{ }}",
                    "type": "string",
                    "pattern": "^\\{\\{[\\s\\S]*\\}\\}$"
                  },
                  {
                    "$ref": "#/$defs/__schema0"
                  }
                ]
              }
            },
            "params": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "required": [
            "type",
            "assignments"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "params": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ],
      "id": "Action"
    },
    "__schema0": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        }
      ]
    },
    "Transition": {
      "type": "object",
      "properties": {
        "target": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "context": {
          "description": "Context assignments applied when this transition is taken. Appended as a core.assign action.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "description": "An expression string delimited by {{ }}",
                "type": "string",
                "pattern": "^\\{\\{[\\s\\S]*\\}\\}$"
              },
              {
                "$ref": "#/$defs/__schema0"
              }
            ]
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Action"
          }
        },
        "description": {
          "type": "string"
        },
        "guard": {
          "$ref": "#/$defs/Guard"
        },
        "meta": {
          "$ref": "#/$defs/Meta"
        },
        "order": {
          "description": "Explicit transition priority",
          "type": "number"
        },
        "reenter": {
          "description": "Whether this transition re-enters target states",
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "id": "Transition"
    },
    "Guard": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "params": {
              "$ref": "#/$defs/__schema0"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        },
        {
          "description": "An expression string delimited by {{ }}",
          "type": "string",
          "pattern": "^\\{\\{[\\s\\S]*\\}\\}$"
        }
      ],
      "id": "Guard"
    },
    "Meta": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      },
      "id": "Meta"
    },
    "Invoke": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "input": {
          "description": "Input passed to the invoked actor",
          "anyOf": [
            {
              "description": "An expression string delimited by {{ }}",
              "type": "string",
              "pattern": "^\\{\\{[\\s\\S]*\\}\\}$"
            },
            {
              "$ref": "#/$defs/__schema0"
            }
          ]
        },
        "meta": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "onDone": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Transition"
              }
            },
            {
              "$ref": "#/$defs/Transition"
            }
          ]
        },
        "onError": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Transition"
              }
            },
            {
              "$ref": "#/$defs/Transition"
            }
          ]
        },
        "onSnapshot": {
          "description": "Transitions triggered when the invoked actor emits a snapshot",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Transition"
              }
            },
            {
              "$ref": "#/$defs/Transition"
            }
          ]
        },
        "timeout": {
          "description": "ISO 8601 duration for invocation timeout",
          "type": "string"
        },
        "heartbeat": {
          "description": "ISO 8601 duration for heartbeat interval",
          "type": "string"
        },
        "retry": {
          "description": "Retry policy for the invoked actor on error",
          "type": "object",
          "properties": {
            "maxAttempts": {
              "description": "Maximum number of retry attempts",
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "interval": {
              "description": "Delay between retries: ms (number) or ISO 8601 duration (string)",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                }
              ]
            },
            "backoff": {
              "description": "Backoff multiplier applied to interval after each retry",
              "type": "number"
            }
          },
          "required": [
            "maxAttempts"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "src"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/__schema0"
      },
      "id": "Invoke"
    },
    "State": {
      "type": "object",
      "properties": {
        "id": {
          "description": "The state node ID",
          "type": "string"
        },
        "description": {
          "description": "The text description of this state node",
          "type": "string"
        },
        "type": {
          "description": "The state type, if not a normal (atomic or compound) state node",
          "anyOf": [
            {
              "type": "string",
              "const": "parallel"
            },
            {
              "type": "string",
              "const": "history"
            },
            {
              "type": "string",
              "const": "final"
            }
          ]
        },
        "target": {
          "description": "The target state for history states",
          "type": "string"
        },
        "history": {
          "description": "The history type for history states",
          "type": "string",
          "enum": [
            "shallow",
            "deep"
          ]
        },
        "entry": {
          "description": "The entry actions",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Action"
          }
        },
        "exit": {
          "description": "The exit actions",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Action"
          }
        },
        "initial": {
          "description": "The initial child state",
          "type": "string"
        },
        "on": {
          "description": "The transitions",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/Transition"
                }
              },
              {
                "$ref": "#/$defs/Transition"
              }
            ]
          }
        },
        "after": {
          "description": "Delayed transitions. Keys can be milliseconds (number as string) or ISO 8601 durations (e.g. PT30S, PT1M).",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/Transition"
                }
              },
              {
                "$ref": "#/$defs/Transition"
              }
            ]
          }
        },
        "always": {
          "description": "Eventless transitions that trigger immediately when their guard is true",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Transition"
              }
            },
            {
              "$ref": "#/$defs/Transition"
            }
          ]
        },
        "onDone": {
          "description": "Transitions triggered when this state reaches done status",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Transition"
              }
            },
            {
              "$ref": "#/$defs/Transition"
            }
          ]
        },
        "invoke": {
          "description": "Invoked actors spawned when the state is entered",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Invoke"
          }
        },
        "tags": {
          "description": "Tags for categorizing this state",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output": {
          "description": "Output data for final states",
          "anyOf": [
            {
              "description": "An expression string delimited by {{ }}",
              "type": "string",
              "pattern": "^\\{\\{[\\s\\S]*\\}\\}$"
            },
            {
              "$ref": "#/$defs/__schema0"
            }
          ]
        },
        "meta": {
          "description": "The metadata for this state node",
          "$ref": "#/$defs/Meta"
        },
        "states": {
          "description": "The child states",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/State"
          }
        }
      },
      "additionalProperties": false,
      "id": "State"
    }
  }
}